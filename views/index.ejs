<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
  </head>
  <body>
    <header>
      <h1>Message Board</h1>
    </header>
    <main>
      <a href="/new">Send a message</a>
      <ol>
          <% messages.forEach(message => { %>
              <%- include("messageCard", {message: message}) %>
          <% }) %>
      </ol>
    </main>
  </body>
</html>
